            </value>
        </assignmentItems>
    </assignments>
    <assignments>
        <name>Use_Found_User</name>
        <label>Use Found User</label>
        <locationX>176</locationX>
        <locationY>360</locationY>
        <assignmentItems>
            <assignToReference>varSelectedUserId</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Search_User_By_Name.Id</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>varSelectedUserName</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Search_User_By_Name.Name</elementReference>
            </value>
        </assignmentItems>
