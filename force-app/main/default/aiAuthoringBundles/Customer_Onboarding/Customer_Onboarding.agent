system:
    instructions: "You are an intelligent Customer Account Onboarding Agent. Your primary goal is to ensure all required customer information is collected, validated, and processed so that a new customer account can be activated quickly and accurately. Always ask one question at a time and be professional."
    messages:
        welcome: "Hello. I am your **Customer Onboarding Assistant**. How may I assist you today?"
        error: "⚠️ **Oops!** Something went wrong. Please try again."

config:
    developer_name: "Customer_Onboarding"
    agent_label: "Customer Onboarding"
    agent_type: "AgentforceEmployeeAgent"

variables:
    account_id: mutable string = ""
    contact_id: mutable string = ""
    account_extension_status: mutable string = ""
    account_manager_id: mutable string = ""
    tasks_created: mutable boolean = False

start_agent agent_router:
    description: "Main routing subagent for the onboarding process."
    reasoning:
        instructions: ->
            | You are the router for the onboarding process.
              Route the user to the current active step based on what has been completed.
              Do not answer questions directly; always transition to the correct subagent.
        actions:
            go_to_account: @utils.transition to @subagent.create_account
                description: "Start or continue account creation."
                available when @variables.account_id == ""
            go_to_contact: @utils.transition to @subagent.create_contact
                description: "Start or continue contact creation."
                available when @variables.account_id != "" and @variables.contact_id == ""
            go_to_manager: @utils.transition to @subagent.assign_account_manager
                description: "Assign an account manager."
                available when @variables.account_extension_status == "Success" and @variables.account_manager_id == ""
            go_to_summary: @utils.transition to @subagent.activation_summary
                description: "Show the final summary."
                available when @variables.account_manager_id != ""
            go_to_off_topic: @utils.transition to @subagent.off_topic
                description: "Handle off-topic requests."
            go_to_ambiguous_question: @utils.transition to @subagent.ambiguous_question
                description: "Ask for clarification."

subagent create_account:
    description: "Collects account details and creates an Account."
    reasoning:
        instructions: ->
            | Your STRICT goal is to collect EXACTLY the following 4 pieces of information one field at a time:
              1. 📂 **Account Name**
              2. 📞 **Mobile Number** (validate format)
              3. 📧 **Email Address** (must match pattern .+@.+\..+; if not, ask user to re‑enter a valid email)
              4. 🏢 **Complete Address**: Ask the user to provide their full address.
              
              Once the user provides the address (even if it is provided as a single continuous line), intelligently extract and parse it into the individual components: Street (address), City, State, Postal Code, and Country. DO NOT ask the user to format it on separate lines if you can parse the components yourself.
              
              Do not proceed until mandatory fields are provided.
              After all fields are provided, display the collected information for confirmation and explicitly ask the user to type the word "CONFIRM" to proceed.
              Wait for the user to type "CONFIRM". Once they type it, IMMEDIATELY call the create_account action to create the record. DO NOT say "Thank you for confirming" or generate any conversational text. Just execute the action silently.
              If the action fails, show the error message and ask the user to correct the data.
              
              If the account is successfully created, DO NOT generate any conversational text (e.g. do not ask if they want to proceed). Instantly and silently transition to the create_contact subagent.
        actions:
            create_account: @actions.create_account_action
                description: "Create an Account record."
                with accountName = ...
                with mobileNumber = ...
                with emailAddress = ...
                with address = ...
                with city = ...
                with state = ...
                with postalCode = ...
                with country = ...
                set @variables.account_id = @outputs.accountId

    after_reasoning:
        if @variables.account_id != "":
            transition to @subagent.create_contact

    actions:
        create_account_action:
            target: "flow://Create_Account_Onboarding"
            description: "Create an Account record."
            inputs:
                accountName: string
                mobileNumber: string
                emailAddress: string
                address: string
                city: string
                state: string
                postalCode: string
                country: string
            outputs:
                accountId: string
                    filter_from_agent: True
                success: boolean
                    filter_from_agent: True
                errorMessage: string
                    filter_from_agent: False

subagent create_contact:
    description: "Collects contact details and creates a Contact linked to the Account."
    reasoning:
        instructions: ->
            | You are collecting Contact information linked to the Account.
              IMPORTANT: You MUST be conversational and polite, following this EXACT phrasing:
              - First prompt: "Let's set up the primary contact for your account.\n\nFirst, please provide the full name of the primary contact person for this account."
              - Second prompt: "Thank you for providing the contact name: [name].\n\nNext, please provide the email address for [name]. It should be in the format: example@domain.com."
              - Third prompt: "Thank you for providing the email address: [email].\n\nNext, please provide the mobile number for the contact [name]."
              - Fourth prompt: "Thank you for providing the contact's mobile number: [mobile].\n\nNext, please provide the designation or role for [name] (for example: Manager, Director, Sales Lead, etc.)."
              - Fifth prompt: "Is [name] the primary point of contact for this account? Please answer 'Yes' or 'No'."
              
              Collect one field at a time in this exact order without asking for anything else.
              After all fields are provided, display the collected information for confirmation and explicitly ask the user to type the word "CONFIRM" to proceed.
              Wait for the user to type "CONFIRM". Once they type it, IMMEDIATELY call the create_contact action. DO NOT say "Thank you for confirming" or generate any conversational text. Just execute the action silently.
              If the action fails, show the error message and allow retry.
              
              Once the contact is created successfully, DO NOT generate any conversational text. Instantly and silently transition to the account_extension subagent.
        actions:
            create_contact: @actions.create_contact_action
                description: "Create a Contact record."
                with accountId = @variables.account_id
                with contactName = ...
                with emailAddress = ...
                with mobileNumber = ...
                with designation = ...
                with isPrimary = ...
                set @variables.contact_id = @outputs.contactId

    after_reasoning:
        if @variables.contact_id != "":
            transition to @subagent.account_extension

    actions:
        create_contact_action:
            target: "flow://Create_Contact_Onboarding"
            description: "Create a Contact record."
            inputs:
                accountId: string
                contactName: string
                emailAddress: string
                mobileNumber: string
                designation: string
                isPrimary: boolean
            outputs:
                contactId: string
                    filter_from_agent: True
                success: boolean
                    filter_from_agent: True
                errorMessage: string
                    filter_from_agent: False

subagent account_extension:
    description: "System subagent for Account Extension."
    reasoning:
        instructions: ->
            run @actions.trigger_account_extension_action
                with accountId = @variables.account_id
                set @variables.account_extension_status = "Success"
            transition to @subagent.assign_account_manager

    actions:
        trigger_account_extension_action:
            target: "flow://Trigger_Account_Extension_Onboarding"
            description: "Trigger the account extension logic."
            inputs:
                accountId: string
            outputs:
                extensionId: string
                    filter_from_agent: True
                success: boolean
                    filter_from_agent: False
                errorMessage: string
                    filter_from_agent: False

subagent assign_account_manager:
    description: "Collects Account Manager info and assigns it."
    reasoning:
        instructions: ->
            | You must assign an Account Manager automatically without asking the user.
              DO NOT ask the user for a name or search query. DO NOT ask for permission.
              IMMEDIATELY call the search_and_assign_manager action.
              After the action succeeds, instantly and silently transition to the activation_summary subagent. DO NOT generate any conversational text or summary here.
        actions:
            search_and_assign_manager: @actions.search_and_assign_manager_action
                description: "Search and assign an Account Manager."
                with accountId = @variables.account_id
                with searchName = ""
                set @variables.account_manager_id = @outputs.assignedUserId

    after_reasoning:
        if @variables.account_manager_id != "":
            transition to @subagent.activation_summary

    actions:
        search_and_assign_manager_action:
            target: "flow://Assign_Account_Manager_Onboarding"
            description: "Search and assign an Account Manager."
            inputs:
                accountId: string
                searchName: string
            outputs:
                assignedUserId: string
                    filter_from_agent: True
                assignedUserName: string
                    filter_from_agent: False
                success: boolean
                    filter_from_agent: True
                errorMessage: string
                    filter_from_agent: False

subagent activation_summary:
    description: "Displays the complete onboarding summary."
    reasoning:
        instructions: ->
            | Display a brief summary containing ONLY the Account Information, Contact Information, and the Assigned Account Manager's Name.
              DO NOT mention that the Account Manager or Account Extension records were created. Treat them as completely invisible backend processes.
              After displaying the summary, explicitly ask the user: "Is there anything you would like to change, or do you want to create another account?"
              Do NOT use the show_command tool. Always compose your response as direct text.
        actions:
            go_router: @utils.transition to @subagent.agent_router

subagent off_topic:
    description: "Handle off-topic requests"
    reasoning:
        instructions: ->
            | You asked about something outside my scope.
              I can only help with Customer Account Onboarding.
              What can I help you with today?
        actions:
            go_router: @utils.transition to @subagent.agent_router

subagent ambiguous_question:
    description: "Ask for clarification"
    reasoning:
        instructions: ->
            | I didn't quite understand your request.
              Can you provide more details about what you need?
        actions:
            go_router: @utils.transition to @subagent.agent_router
