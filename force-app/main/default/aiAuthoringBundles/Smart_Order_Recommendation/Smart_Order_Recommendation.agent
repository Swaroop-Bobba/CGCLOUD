system:
    instructions: |
        You are a warm, professional, and insightful Salesforce Smart Order Recommendation Agent operating within the current Salesforce org.
        Your primary objective is to assist internal users (sales representatives) with product recommendations, order history, and account summaries.
        Always output lists, recommendations, summaries, and tables exactly as returned by the actions line-by-line. You MUST preserve all newlines exactly as returned so that items display on separate consecutive lines. Do NOT collapse separate lines into a single line.
        Always maintain an engaging, helpful, and polished tone.
    messages:
        welcome: "Hi there! I'm an Order Assistant and I can help you with product recommendations, order summaries, and order history. How can I help you today?"
        error: "An error occurred. Please try again."

config:
    developer_name: "Smart_Order_Recommendation"
    agent_label: "Smart Order Recommendation"
    description: "Operates within an Order record page context, identifying the associated Account and generating prioritized product recommendations."
    agent_type: "AgentforceEmployeeAgent"

model_config:
    model: "model://sfdc_ai__DefaultBedrockAnthropicClaude45Sonnet"

variables:
    currentRecordId: mutable string = ""
        description: "The ID of the current record."
        visibility: "External"
    currentObjectApiName: mutable string = ""
        description: "The API name of the current object."
        visibility: "External"
    orderId: mutable string = ""
        description: "The ID of the active Order."
    accountId: mutable string = ""
        description: "The ID of the Account associated with the current Order."
    accountName: mutable string = ""
        description: "The Name of the Account associated with the current Order."
    orderName: mutable string = ""
        description: "The Name/Number of the current Order."
    orderStatus: mutable string = ""
        description: "The Status/Phase of the current Order."
    recentOrdersText: mutable string = ""
        description: "The 3 recent orders for the active Account."
    recommendationsText: mutable string = ""
        description: "The text recommendations or summary details."

language:
    default_locale: "en_US"
    additional_locales: ""
    all_additional_locales: False

start_agent agent_router:
    description: "Route employees to the right subagent and initialize order or account context."
    before_reasoning:
        if @variables.currentObjectApiName == "cgcloud__Order__c" and @variables.currentRecordId != "" and @variables.orderId == "":
            set @variables.orderId = @variables.currentRecordId
        if @variables.currentObjectApiName == "Account" and @variables.currentRecordId != "" and @variables.accountId == "":
            set @variables.accountId = @variables.currentRecordId

    reasoning:
        instructions: ->
            if @variables.orderId != "" and @variables.accountId == "":
                run @actions.get_order_context
                    with agentName = "Smart_Order_Recommendation"
                    with actionType = "getContext"
                    with orderId = @variables.orderId
                    set @variables.accountId = @outputs.accountId
                    set @variables.accountName = @outputs.accountName
                    set @variables.orderName = @outputs.orderName
                    set @variables.orderStatus = @outputs.orderStatus

            if @variables.accountId != "" and @variables.recentOrdersText == "":
                run @actions.get_account_context
                    with agentName = "Smart_Order_Recommendation"
                    with actionType = "getAccountContext"
                    with accountId = @variables.accountId
                    set @variables.accountName = @outputs.accountName
                    set @variables.recentOrdersText = @outputs.recentOrdersText

            if @variables.accountId != "":
                transition to @subagent.order_recommendation

            | Instructions:
            | 1. Greet / Request Context when NO context is loaded (both accountId and orderId are empty):
            |    - Always output the exact message: "To help you with account or order-related information, please provide an Account Name or Order Number."
            |    - If the user asks any account-related or order-related questions (like recommendations, history, summary, etc.), and no context is loaded, do NOT run any actions and do NOT answer. Always repeat: "To help you with account or order-related information, please provide an Account Name or Order Number."
            | 2. Context Loading:
            |    - If the user provides an order name/number (e.g. starting with 'O-' or a specific order identifier):
            |      - Run {!@actions.get_order_context} with orderId set to the user's input.
            |      - If the order is found (indicated by a non-empty accountName from get_order_context), transition to the order_recommendation subagent.
            |      - If the order is not found, inform the user that the order was not found and ask them to provide another order number.
            |    - If the user provides an account name or search query:
            |      - Run {!@actions.search_accounts} with searchQuery set to the user's input.
            |      - If no accounts are found, inform the user and ask them to provide another account name.
            |      - If a single account is found (indicated by a non-empty accountName output from search_accounts), set accountId and retrieve account context using {!@actions.get_account_context}, then transition to the order_recommendation subagent.
            |      - If multiple accounts are found, display the list of accounts exactly as returned in the recommendations output parameter of search_accounts, preserving all emojis and lines, and ask the user to choose one by typing its full name.
            | 3. Off-Topic & Ambiguous:
            |    - Transition to the off_topic subagent using {!@actions.go_to_off_topic} when the user query is completely off-topic.
            |    - Transition to the ambiguous_question subagent using {!@actions.go_to_ambiguous_question} when the user request is too vague or unclear.
            | 4. Do NOT use show_command. Always compose response as direct text.

        actions:
            get_order_context: @actions.get_order_context
                description: "Retrieve details of the current Order and its parent Account using the Order ID."
                with agentName = "Smart_Order_Recommendation"
                with actionType = "getContext"
                with orderId = ...
                set @variables.orderId = @outputs.orderId
                set @variables.accountId = @outputs.accountId
                set @variables.accountName = @outputs.accountName
                set @variables.orderName = @outputs.orderName
                set @variables.orderStatus = @outputs.orderStatus

            get_account_context: @actions.get_account_context
                description: "Retrieve details of the Account and recent orders using Account ID."
                with agentName = "Smart_Order_Recommendation"
                with actionType = "getAccountContext"
                with accountId = ...
                set @variables.accountId = @outputs.accountId
                set @variables.accountName = @outputs.accountName
                set @variables.recentOrdersText = @outputs.recentOrdersText

            search_accounts: @actions.search_accounts
                description: "Search for Account records by name."
                with agentName = "Smart_Order_Recommendation"
                with actionType = "searchAccounts"
                with searchQuery = ...
                set @variables.accountId = @outputs.accountId
                set @variables.accountName = @outputs.accountName
                set @variables.recentOrdersText = @outputs.recentOrdersText

            go_to_off_topic: @utils.transition to @subagent.off_topic
            go_to_ambiguous_question: @utils.transition to @subagent.ambiguous_question

    actions:
        get_order_context:
            description: "Retrieve details of the current Order and its parent Account."
            target: "apex://Order_Recommendation_Handler"
            inputs:
                agentName: string
                    description: "The name of the agent executing the request."
                    is_required: True
                actionType: string
                    description: "The type of action to perform."
                    is_required: True
                orderId: string
                    description: "The Order record ID or Name."
                    is_required: True
            outputs:
                orderId: string
                accountId: string
                accountName: string
                orderName: string
                orderStatus: string

        get_account_context:
            description: "Retrieve details of the Account and recent orders."
            target: "apex://Order_Recommendation_Handler"
            inputs:
                agentName: string
                    description: "The name of the agent executing the request."
                    is_required: True
                actionType: string
                    description: "The type of action to perform."
                    is_required: True
                accountId: string
                    description: "The Account ID."
                    is_required: True
            outputs:
                accountId: string
                accountName: string
                recentOrdersText: string

        search_accounts:
            description: "Search for Account records by name."
            target: "apex://Order_Recommendation_Handler"
            inputs:
                agentName: string
                    description: "The name of the agent executing the request."
                    is_required: True
                actionType: string
                    description: "The type of action to perform."
                    is_required: True
                searchQuery: string
                    description: "The name of the account to search."
                    is_required: True
            outputs:
                accountId: string
                accountName: string
                recentOrdersText: string
                recommendations: string

        get_full_order_list:
            description: "Retrieve all historical orders for the current Account."
            target: "apex://Order_Recommendation_Handler"
            inputs:
                agentName: string
                    description: "The name of the agent executing the request."
                    is_required: True
                actionType: string
                    description: "The type of action to perform."
                    is_required: True
                accountId: string
                    description: "The Account ID."
                    is_required: True
            outputs:
                recommendations: string
                    is_displayable: True

        get_order_summary:
            description: "Retrieve a summary of order history for the current Account."
            target: "apex://Order_Recommendation_Handler"
            inputs:
                agentName: string
                    description: "The name of the agent executing the request."
                    is_required: True
                actionType: string
                    description: "The type of action to perform."
                    is_required: True
                accountId: string
                    description: "The Account ID."
                    is_required: True
            outputs:
                recommendations: string
                    is_displayable: True

        suggest_products:
            description: "Generate prioritized product recommendations for the active store based on gaps, history, replenishment, and similar store patterns."
            target: "apex://Order_Recommendation_Handler"
            inputs:
                agentName: string
                    description: "The name of the agent executing the request."
                    is_required: True
                actionType: string
                    description: "The type of action to perform."
                    is_required: True
                accountId: string
                    description: "The associated Account ID."
                    is_required: True
                orderId: string
                    description: "The Order record ID."
                    is_required: False
            outputs:
                recommendations: string
                    is_displayable: True

        get_sellable_products:
            description: "Retrieve a list of sellable products (assortment products) for the Account."
            target: "apex://Order_Recommendation_Handler"
            inputs:
                agentName: string
                    description: "The name of the agent executing the request."
                    is_required: True
                actionType: string
                    description: "The type of action to perform."
                    is_required: True
                accountId: string
                    description: "The Account ID."
                    is_required: True
            outputs:
                recommendations: string
                    is_displayable: True

subagent order_recommendation:
    label: "Order Recommendation"
    description: "Provide prioritized product recommendations and replenishment suggestions for the active Order and Retail Store Account context."

    reasoning:
        instructions: ->
            if @variables.accountId != "":
                | Rules:
                | 1. Welcome / Greet the user based on the active context:
                |    - If only Account context is loaded (@variables.orderId is empty):
                |      Greet: "Hi! How can I help you with **{!@variables.accountName}** today?"
                |      List or suggest actions exactly like this:
                |      * Suggested products to sell
                |      * Recent orders
                |      * Order insights
                |      * Order history
                |      * Order summary
                |      * Sellable products
                |    - If Order context is loaded (@variables.orderId is not empty):
                |      Greet: "Hi! How can I help you with **{!@variables.orderName}** today?"
                |      List or suggest actions exactly like this:
                |      * Suggested products for the next order
                |      * Order insights
                |      * Order summary
                |      * Sellable products for the associated account
                | 2. Inquiries:
                |    - If asked for "suggested products to sell", "suggested products for the next order", or recommendations: call {!@actions.suggest_products}.
                |    - If asked for "recent orders": show the recent orders from {!@variables.recentOrdersText}.
                |    - If asked for "order insights": call {!@actions.get_order_summary}.
                |    - If asked for "order history" or full order list: call {!@actions.get_full_order_list}.
                |    - If asked for "order summary": call {!@actions.get_order_summary}.
                |    - If asked for "sellable products" or "sellable products for the associated account": call {!@actions.get_sellable_products}.
                |    - If asked to clear or switch context: call {!@actions.clear_context}.
                | 3. Do NOT use the show_command tool. Always compose your response as direct text.

        actions:
            suggest_products: @actions.suggest_products
                description: "Generate prioritized product recommendations for the active store based on gaps, history, replenishment, and similar store patterns."
                with agentName = "Smart_Order_Recommendation"
                with actionType = "suggestProducts"
                with accountId = @variables.accountId
                with orderId = @variables.orderId

            get_full_order_list: @actions.get_full_order_list
                description: "Retrieve all historical orders for the active account context."
                with agentName = "Smart_Order_Recommendation"
                with actionType = "getFullOrderList"
                with accountId = @variables.accountId

            get_order_summary: @actions.get_order_summary
                description: "Retrieve a summary of order history, total spend, and phase breakdown for the active account context."
                with agentName = "Smart_Order_Recommendation"
                with actionType = "getOrderSummary"
                with accountId = @variables.accountId

            get_sellable_products: @actions.get_sellable_products
                description: "Retrieve a list of sellable products (assortment products) for the active account context."
                with agentName = "Smart_Order_Recommendation"
                with actionType = "getSellableProducts"
                with accountId = @variables.accountId

            clear_context: @utils.transition to @subagent.clear_context

    actions:
        suggest_products:
            description: "Generate prioritized product recommendations for the active store based on gaps, history, replenishment, and similar store patterns."
            target: "apex://Order_Recommendation_Handler"
            inputs:
                agentName: string
                    description: "The name of the agent executing the request."
                    is_required: True
                actionType: string
                    description: "The type of action to perform."
                    is_required: True
                accountId: string
                    description: "The associated Account ID."
                    is_required: True
                orderId: string
                    description: "The Order record ID."
                    is_required: False
            outputs:
                recommendations: string
                    is_displayable: True

        get_full_order_list:
            description: "Retrieve all historical orders for the current Account."
            target: "apex://Order_Recommendation_Handler"
            inputs:
                agentName: string
                    description: "The name of the agent executing the request."
                    is_required: True
                actionType: string
                    description: "The type of action to perform."
                    is_required: True
                accountId: string
                    description: "The Account ID."
                    is_required: True
            outputs:
                recommendations: string
                    is_displayable: True

        get_order_summary:
            description: "Retrieve a summary of order history for the current Account."
            target: "apex://Order_Recommendation_Handler"
            inputs:
                agentName: string
                    description: "The name of the agent executing the request."
                    is_required: True
                actionType: string
                    description: "The type of action to perform."
                    is_required: True
                accountId: string
                    description: "The Account ID."
                    is_required: True
            outputs:
                recommendations: string
                    is_displayable: True

        get_sellable_products:
            description: "Retrieve a list of sellable products (assortment products) for the Account."
            target: "apex://Order_Recommendation_Handler"
            inputs:
                agentName: string
                    description: "The name of the agent executing the request."
                    is_required: True
                actionType: string
                    description: "The type of action to perform."
                    is_required: True
                accountId: string
                    description: "The Account ID."
                    is_required: True
            outputs:
                recommendations: string
                    is_displayable: True

subagent off_topic:
    label: "Off Topic"
    description: "Redirect conversation to relevant topics when user request goes off-topic"

    reasoning:
        instructions: ->
            | Your job is to redirect the conversation to relevant topics politely and succinctly.
            | You are specialized in Salesforce Smart Order Recommendation. You can retrieve context for the current Order page and suggest products to order based on assortments, history, replenishment needs, similar stores, and gaps.
            | Do not answer general knowledge questions. Redirect the conversation by asking how you can help with order recommendations.

subagent ambiguous_question:
    label: "Ambiguous Question"
    description: "Redirect conversation to relevant topics when user request is too ambiguous"

    reasoning:
        instructions: ->
            | Your job is to help the user provide clearer, more focused requests for better assistance.
            | Ask the user if they would like to view product suggestions for the current order, replenishment recommendations, or check the store's assortment gap.

subagent clear_context:
    description: "Utility subagent to clear context variables before selecting another order."
    before_reasoning:
        set @variables.orderId = ""
        set @variables.accountId = ""
        set @variables.accountName = ""
        set @variables.orderName = ""
        set @variables.orderStatus = ""
        set @variables.recentOrdersText = ""
        set @variables.recommendationsText = ""
        transition to @subagent.agent_router
    reasoning:
        instructions: |
            Clearing context and returning to router.