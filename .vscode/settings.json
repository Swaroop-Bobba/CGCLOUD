{
  "search.exclude": {
    "**/node_modules": true,
    "**/bower_components": true,
    "**/.sf": true,
    "**/.sfdx": true
  },
  "xml.preferences.showSchemaDocumentationType": "none",
  "xml.validation.schema": "never",
  "xml.validation.filters": [
    {
      "pattern": "**/*-meta.xml",
      "enabled": false
    }
  ],
  "git.ignoreLimitWarning": true,
  "salesforcedx-vscode-core.show-cli-success-msg": false
}
